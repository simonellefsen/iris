		"jsdom": "^29.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"dexie": "^4.4.4",
